#!/usr/bin/env bash
# Client-side protection for branches that can't be protected via GitHub
# rulesets on the Free plan.
# Blocks: force-push and deletion of listed protected refs.
# Bypass (only when truly intentional): PROTECTED_BRANCHES_OVERRIDE=1 git push ...
#
# Customise the PROTECTED regex below to match your team's branch convention.
# The default protects `main`, plus a typical `<version>-dev` and `<version>.0`
# pair (e.g. `19-dev` / `19.0` for an Odoo-style flow). Adapt as needed.

set -e

PROTECTED='^(main|[0-9]+-dev|[0-9]+\.[0-9]+)$'
ZERO='0000000000000000000000000000000000000000'

if [ "${PROTECTED_BRANCHES_OVERRIDE:-0}" = "1" ]; then
  echo "pre-push: PROTECTED_BRANCHES_OVERRIDE=1 — skipping protection checks" >&2
  exit 0
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  branch="${remote_ref#refs/heads/}"
  if ! echo "$branch" | grep -Eq "$PROTECTED"; then
    continue
  fi

  if [ "$local_sha" = "$ZERO" ]; then
    echo "pre-push: refusing to DELETE protected branch '$branch'." >&2
    echo "          If this is intentional: PROTECTED_BRANCHES_OVERRIDE=1 git push ..." >&2
    exit 1
  fi

  if [ "$remote_sha" != "$ZERO" ]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      echo "pre-push: refusing NON-FAST-FORWARD push to protected branch '$branch'." >&2
      echo "          Remote $remote_sha is not an ancestor of local $local_sha." >&2
      echo "          If this is intentional: PROTECTED_BRANCHES_OVERRIDE=1 git push ..." >&2
      exit 1
    fi
  fi
done

exit 0
